{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "apps",
  "projects": {
    "morador": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": { "style": "scss", "standalone": true }
      },
      "root": "apps/morador",
      "sourceRoot": "apps/morador/src",
      "prefix": "cm",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/morador",
            "index": "apps/morador/src/index.html",
            "browser": "apps/morador/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/morador/tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "apps/morador/src/assets", "output": "assets" }],
            "styles": ["apps/morador/src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "500kB", "maximumError": "1MB" },
                { "type": "anyComponentStyle", "maximumWarning": "4kB", "maximumError": "8kB" }
              ],
              "outputHashing": "all"
            },
            "development": { "optimization": false, "extractLicenses": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "morador:build:production" },
            "development": { "buildTarget": "morador:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    },
    "porteiro": {
      "projectType": "application",
      "schematics": {
        "@schematics/angular:component": { "style": "scss", "standalone": true }
      },
      "root": "apps/porteiro",
      "sourceRoot": "apps/porteiro/src",
      "prefix": "cm",
      "architect": {
        "build": {
          "builder": "@angular-devkit/build-angular:application",
          "options": {
            "outputPath": "dist/porteiro",
            "index": "apps/porteiro/src/index.html",
            "browser": "apps/porteiro/src/main.ts",
            "polyfills": ["zone.js"],
            "tsConfig": "apps/porteiro/tsconfig.app.json",
            "assets": [{ "glob": "**/*", "input": "apps/porteiro/src/assets", "output": "assets" }],
            "styles": ["apps/porteiro/src/styles.scss"],
            "scripts": []
          },
          "configurations": {
            "production": {
              "budgets": [
                { "type": "initial", "maximumWarning": "500kB", "maximumError": "1MB" },
                { "type": "anyComponentStyle", "maximumWarning": "4kB", "maximumError": "8kB" }
              ],
              "outputHashing": "all"
            },
            "development": { "optimization": false, "extractLicenses": false, "sourceMap": true }
          },
          "defaultConfiguration": "production"
        },
        "serve": {
          "builder": "@angular-devkit/build-angular:dev-server",
          "configurations": {
            "production": { "buildTarget": "porteiro:build:production" },
            "development": { "buildTarget": "porteiro:build:development" }
          },
          "defaultConfiguration": "development"
        }
      }
    }
  }
}
